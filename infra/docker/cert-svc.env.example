# idcd cert-svc 生产环境配置模板
# 部署路径: /opt/idcd/config/cert-svc.env（不入 git）
# 读取此文件的服务: cert-svc / cert-worker / cert-renewer（同一镜像三个 CMD）
#
# 配置加载: apps/cert-svc/internal/config/config.go 直接读 CERT_* env vars
# (不走 lib/shared/config 的 YAML 路径)
#
# 生成随机密钥:
#   MASTER_KEY / DOWNLOAD_SECRET / JWT_SECRET: openssl rand -base64 32
#   ADMIN_TOKEN: openssl rand -hex 32
#
# ⚠️ 严禁复用 dev 全零 MASTER_KEY (AAAA...=)
# ⚠️ 任何标 "CHANGE_ME" 的字段必须替换，否则启动期 fail-fast 或后续接口 401

# ── 网络端口 ──────────────────────────────────────────────────────
# 容器内监听端口。docker-compose.prod.yml 把 8080 映射到宿主 8086。
# 同时 prod.env.yaml 的 cert_svc_url 必须指向此端口 (http://cert-svc:8080)。
CERT_SVC_PORT=8080
CERT_SVC_METRICS_PORT=9090

# ── 数据库 + Redis(云托管,跟主库共享) ──────────────────────────
# 注意 cert.* 表跨 schema 不写 FK,跟主库同一个实例即可。
CERT_DB_DSN=postgresql://idcd:CHANGE_ME@云DB_HOST:5432/idcd?sslmode=require
CERT_REDIS_ADDR=云REDIS_HOST:6379
CERT_REDIS_PASSWORD=CHANGE_ME
CERT_REDIS_DB=0

# ── 运行环境 ─────────────────────────────────────────────────────
CERT_ENV=production
CERT_LOG_LEVEL=info
# Let's Encrypt 环境: "production" = 真证书 / "staging" = 测试证书(60签速率不限)
# 上线前先用 staging 跑 1-2 单冒烟,确认链路再切 production
CERT_LE_ENV=staging
# ACME account 注册邮箱,LE 用此邮箱发到期 / 吊销提醒
CERT_ACME_ACCOUNT_EMAIL=acme@idcd.com

# ── 认证密钥 ─────────────────────────────────────────────────────
# JWT_SECRET: 必须跟 apps/api 的 jwt.secret 完全一致(prod.env.yaml)
# 否则 api 反代过来的 JWT 在 cert-svc 验签失败 → 全部 401
CERT_JWT_SECRET=CHANGE_ME_SAME_AS_PROD_ENV_YAML_JWT_SECRET

# ADMIN_TOKEN: /v1/admin/cert/* 的 Bearer 守卫,后台运维用
# 跟 prod.env.yaml 的 server.admin_token 可以不同(独立轮换)
CERT_ADMIN_TOKEN=CHANGE_ME_openssl_rand_hex_32

# ── 加密密钥 ─────────────────────────────────────────────────────
# MASTER_KEY: base64 编码 32 字节,envmaster vault backend 用
# ⚠️ 仅当 CERT_VAULT_BACKEND=envmaster 时生效;生产建议切到 alikms 降低单机依赖
# 生成: openssl rand -base64 32
CERT_MASTER_KEY=CHANGE_ME_openssl_rand_base64_32

# DOWNLOAD_SECRET: base64 编码 (>=16 字节解码后) HMAC-SHA256 key
# 用于 W5 一次性证书下载令牌签名;留空则 /v1/cert/certs/{id}/download 返回 503
# 生成: openssl rand -base64 32
CERT_DOWNLOAD_SECRET=CHANGE_ME_openssl_rand_base64_32

# ── Vault Backend 选择 (D-FC-04) ─────────────────────────────────
# envmaster: 用 CERT_MASTER_KEY 做进程本地 AES (S1 兼容,单机失效有数据丢失风险)
# alikms:    Aliyun KMS 信封加密 (国内主路径,推荐生产用)
# awskms:    AWS KMS 信封加密 (海外部署用)
# hashivault: HashiCorp Vault transit (自建 KMS 用)
CERT_VAULT_BACKEND=envmaster

# ── Aliyun KMS (CERT_VAULT_BACKEND=alikms 时必填) ──────────────
# 创建 AccessKey: https://ram.console.aliyun.com/
# 授予权限: AliyunKMSFullAccess (或更细粒度的 KMS 加解密权限)
# CERT_ALIKMS_REGION_ID=cn-hangzhou
# CERT_ALIKMS_ACCESS_KEY_ID=LTAI5tCHANGE_ME
# CERT_ALIKMS_ACCESS_KEY_SECRET=CHANGE_ME
# CERT_ALIKMS_KEY_ID=key-CHANGE_ME

# ── AWS KMS (CERT_VAULT_BACKEND=awskms 时必填) ─────────────────
# Region 和 KeyID 必填;静态 IAM 可选,留空走默认凭证链(IRSA / instance profile)
# CERT_AWSKMS_REGION=ap-southeast-1
# CERT_AWSKMS_KEY_ID=arn:aws:kms:ap-southeast-1:xxx:key/xxx-xxx-xxx
# CERT_AWSKMS_ACCESS_KEY_ID=AKIA...        # 可选,留空走默认凭证链
# CERT_AWSKMS_SECRET_ACCESS_KEY=...        # 可选,跟上面同时设/同时不设

# ── HashiCorp Vault (CERT_VAULT_BACKEND=hashivault 时必填) ─────
# CERT_HASHIVAULT_ADDRESS=https://vault.example.com:8200
# CERT_HASHIVAULT_TOKEN=hvs.CHANGE_ME
# CERT_HASHIVAULT_KEY_NAME=cert-svc
# CERT_HASHIVAULT_NAMESPACE=                # 可选,Vault Enterprise 用
# CERT_HASHIVAULT_MOUNT_PATH=transit        # 可选,默认 transit

# ── 第三方 CA EAB(可选,留空则该 CA 不注册到 Router)──────────
# ZeroSSL (https://app.zerossl.com/developer)
# CERT_ZEROSSL_EAB_KID=
# CERT_ZEROSSL_EAB_HMAC_KEY=
# Buypass Go SSL (production / staging,留空禁用)
# CERT_BUYPASS_ENV=
