{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "idcd locale registry",
  "type": "object",
  "required": ["default", "locales"],
  "properties": {
    "default": {
      "type": "string",
      "description": "Default locale code; must appear in locales[].code"
    },
    "locales": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "code",
          "bcp47",
          "label",
          "nativeLabel",
          "baseLanguage",
          "acceptLanguageAliases",
          "dir",
          "fontStack",
          "fallback"
        ],
        "properties": {
          "code": {
            "type": "string",
            "pattern": "^[a-z]{2,5}$",
            "description": "Internal short code used in URLs, DB, API"
          },
          "bcp47": {
            "type": "string",
            "pattern": "^[a-z]{2}(-[A-Z][a-z]{3})?(-[A-Z]{2})?$",
            "description": "Standard BCP 47 tag for HTML lang, hreflang, Intl.* APIs"
          },
          "label": { "type": "string" },
          "nativeLabel": { "type": "string" },
          "baseLanguage": {
            "type": "string",
            "pattern": "^[a-z]{2,3}$"
          },
          "acceptLanguageAliases": {
            "type": "array",
            "items": { "type": "string" }
          },
          "dir": { "enum": ["ltr", "rtl"] },
          "fontStack": { "type": "string" },
          "fallback": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Extra fallback chain entries (default + baseLanguage auto-appended)"
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
