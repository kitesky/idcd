[Unit]
Description=idcd Agent Node
Documentation=https://github.com/kite365/idcd
After=network.target
Wants=network.target

[Service]
Type=simple
User=idcd-agent
Group=idcd-agent
ExecStart=/usr/local/bin/idcd-agent
Restart=always
RestartSec=5
KillMode=mixed
KillSignal=SIGTERM
TimeoutStopSec=30

# Environment variables
Environment=AGENT_DATA_DIR=/var/lib/idcd-agent
Environment=IDCD_CONFIG=/etc/idcd-agent/config.yaml

# Security hardening
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=strict
ProtectHome=true
ReadWritePaths=/var/lib/idcd-agent /var/log/idcd-agent
ProtectKernelTunables=true
ProtectKernelModules=true
ProtectControlGroups=true
RestrictRealtime=true
RestrictNamespaces=true
LockPersonality=true
MemoryDenyWriteExecute=true
RestrictAddressFamilies=AF_UNIX AF_INET AF_INET6

# Capabilities for ICMP ping (optional, agent can work without)
AmbientCapabilities=CAP_NET_RAW
CapabilityBoundingSet=CAP_NET_RAW

# Resource limits
MemoryMax=512M
TasksMax=100

# Logging
StandardOutput=journal
StandardError=journal
SyslogIdentifier=idcd-agent

[Install]
WantedBy=multi-user.target