# OS
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db

# Claude Code local settings (personal, not for sharing)
.claude/settings.local.json

# Editor
.vscode/
.idea/
*.swp
*.swo

# Node
node_modules/
.env
.env.local
.env.*.local

# Build outputs
dist/
build/
.next/
.turbo/
.open-next/
.wrangler/
out/
*.tsbuildinfo

# Logs
*.log
npm-debug.log*
pnpm-debug.log*

# Go
*.exe
*.test
*.out
vendor/

# Config (actual env files; *.example.yaml is tracked)
backend/config/*.env.yaml
!backend/config/*.env.example.yaml
backend/config/*.local.yaml
backend/config/aggregator.yaml
!backend/config/aggregator.example.yaml

# Secrets / certs (never commit)
*.pem
*.key
*.p12
*.pfx
*.crt
*.jks

# GeoIP databases (download via backend/scripts/download-geolite2.sh — license-bound)
*.mmdb
backend/infra/terraform/.terraform/
backend/infra/terraform/terraform.tfstate*
backend/infra/terraform/*.tfvars
!backend/infra/terraform/*.tfvars.example

# Binary artifacts (Go service builds; both top-level legacy and backend/-rooted)
bin/
dist-agent/
backend/agent
backend/aggregator
backend/scheduler
backend/gateway
backend/notifier
backend/api
backend/bin/
backend/dist-agent/

# Misc
.turbo
.vercel

# Playwright artifacts (E2E test outputs, not source)
frontend/test-results/
frontend/playwright-report/
frontend/tests/e2e/.auth/

# Heap snapshots / profiles (debug-only, can be hundreds of MB)
*.heapsnapshot
*.heapprofile
.heap-profile/
frontend/.heap-profile/

.devfleet-worktrees/
.gstack/
.claude/worktrees/
