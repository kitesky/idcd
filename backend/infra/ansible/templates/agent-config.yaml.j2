# /etc/idcd-agent/config.yaml
# Generated by Ansible — do NOT edit manually.
# Re-deploy with: ansible-playbook -i inventory/hosts.yml agent.yml

node_id: "{{ node_id }}"
gateway_url: "{{ gateway_wss_url }}"
heartbeat_interval: {{ node_heartbeat_interval }}
log_level: "{{ agent_log_level }}"
sqlite_path: "{{ agent_sqlite_path }}"
max_cache_mb: {{ agent_max_cache_mb }}

# Node metadata (informational; not used by the binary at runtime)
node_region: "{{ node_region | default('unknown') }}"
node_tier: "{{ node_tier | default('tier2') }}"
node_isp: "{{ node_isp | default('unknown') }}"

# Local health-check HTTP server
health_port: {{ agent_health_port }}
